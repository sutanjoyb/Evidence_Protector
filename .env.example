# Evidence Protector Pro — Environment Configuration
# Copy this file to .env and fill in your values

# Secret key used for signing JWTs
# Secret key used for signing tokens / sessions
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# How long access tokens remain valid (in minutes)
# Generate a strong secret key, e.g: openssl rand -hex 32
SECRET_KEY=your-strong-random-secret-key-here

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
